# opensdmx — Configuration
# Copy to .env and uncomment the values you want to override.

# Google Gemini API key (required for `guide` command)
# Get one at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-key-here

# Cache TTL configuration (seconds)
# Override any value to customise how long cached data is kept.

# Dataflow catalog (parquet file) — default: 604800 (7 days)
# OPENSDMX_DATAFLOWS_CACHE_TTL=604800

# Structure dimensions + codelist descriptions/values (SQLite) — default: 2592000 (30 days)
# OPENSDMX_METADATA_CACHE_TTL=2592000

# Available constraints per dataflow (SQLite) — default: 604800 (7 days)
# OPENSDMX_CONSTRAINTS_CACHE_TTL=604800
